{
  "name": "solidjs-state",
  "version": "0.1.1",
  "description": "A unified state helper for SolidJS that chooses signal or store for you.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "solid",
    "solid-js",
    "state",
    "signal",
    "store"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "peerDependencies": {
    "solid-js": ">=1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "solid-js": "^1.9.6"
  }
}
